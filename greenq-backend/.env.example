# Local development example
SERVER_PORT=8081
DB_HOST=localhost
DB_PORT=3307
DB_NAME=greenq
DB_USERNAME=testuser
DB_PASSWORD=replace-with-local-password
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
TZ=Asia/Seoul
JAVA_TOOL_OPTIONS=-Duser.timezone=Asia/Seoul

