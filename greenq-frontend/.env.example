# Local development
# The frontend can also use the Vite /api proxy, but this explicit value is useful
# when testing from a tablet or when the backend is not served through the proxy.
VITE_API_BASE_URL=http://localhost:8081/api
VITE_PUBLIC_APP_URL=http://localhost:5173
VITE_DEV_API_PROXY_TARGET=http://localhost:8081

# Production examples
# VITE_API_BASE_URL=https://greenq-production.up.railway.app/api
# VITE_PUBLIC_APP_URL=https://greenq.vercel.app
